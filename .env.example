# === NileFlow Environment Variables ===
# Copy this file to .env and fill in your values

# --- Data Source API Keys ---
TOMTOM_API_KEY=your_tomtom_api_key_here
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here

# --- PostgreSQL ---
POSTGRES_DB=nileflow
POSTGRES_USER=nileflow
POSTGRES_PASSWORD=nileflow_dev

# --- Cassandra ---
CASSANDRA_KEYSPACE=nileflow

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Spark ---
SPARK_MASTER=spark://spark-master:7077

# --- Polling Intervals (seconds) ---
TRAFFIC_POLL_INTERVAL=120
WEATHER_POLL_INTERVAL=300
VEHICLE_POSITION_INTERVAL=10
